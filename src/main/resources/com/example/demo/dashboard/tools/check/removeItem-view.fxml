<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #d9d9d9;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="CONTROLLER_NAME">
   <children>
      <VBox alignment="CENTER" prefHeight="600.0" prefWidth="800.0">
         <children>
            <VBox alignment="CENTER" maxWidth="-Infinity" prefHeight="200.0" prefWidth="400.0" style="-fx-border-color: black;">
               <children>
                  <Label text="CONFIRMAR EXCLUSÃO DO PRODUTO?">
                     <font>
                        <Font name="Droid Sans Bold" size="18.0" />
                     </font>
                  </Label>
                  <Label text="(Nome do produto)">
                     <font>
                        <Font name="Droid Sans Bold" size="14.0" />
                     </font>
                     <VBox.margin>
                        <Insets top="5.0" />
                     </VBox.margin>
                  </Label>
                  <Button mnemonicParsing="false" prefWidth="200.0" style="-fx-border-color: black;" text="CONFIRMAR">
                     <VBox.margin>
                        <Insets top="15.0" />
                     </VBox.margin>
                     <font>
                        <Font name="Droid Sans Bold" size="14.0" />
                     </font>
                  </Button>
                  <Button mnemonicParsing="false" prefWidth="200.0" style="-fx-border-color: black;" text="CANCELAR">
                     <font>
                        <Font name="Droid Sans Bold" size="14.0" />
                     </font>
