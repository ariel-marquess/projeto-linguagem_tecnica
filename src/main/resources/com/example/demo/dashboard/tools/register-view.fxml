<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #d9d9d9;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo.application.controllers.dashboard.tools.Register">
   <children>
      <VBox prefHeight="600.0" prefWidth="800.0">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="60.0" prefWidth="800.0" style="-fx-border-color: black;">
               <children>
                  <Label text="ARMAZÉM &gt; CADASTRAR PRODUTO">
                     <HBox.margin>
                        <Insets left="20.0" />
                     </HBox.margin>
                     <font>
                        <Font name="Droid Sans Bold" size="18.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
            <HBox prefHeight="540.0" prefWidth="800.0">
               <children>
                  <VBox maxWidth="-Infinity" prefHeight="200.0" prefWidth="300.0">
                     <children>
                        <Label text="Nome do produto">
                           <font>
                              <Font name="Droid Sans Bold" size="12.0" />
                           </font>
                           <VBox.margin>
                              <Insets bottom="3.0" left="2.0" />
                           </VBox.margin>
                        </Label>
                        <TextField fx:id="nome" style="-fx-border-color: black;" />
                        <Label text="Quantidade de produto">
                           <VBox.margin>
                              <Insets bottom="3.0" left="2.0" top="10.0" />
                           </VBox.margin>
                           <font>
                              <Font name="Droid Sans Bold" size="12.0" />
                           </font>
                        </Label>
                        <TextField fx:id="quantidade" style="-fx-border-color: black;" />
                        <Label text="Valor unitário do produto">
                           <VBox.margin>
                              <Insets bottom="3.0" left="2.0" top="10.0" />
                           </VBox.margin>
                           <font>
                              <Font name="Droid Sans Bold" size="12.0" />
                           </font>
                        </Label>
                        <TextField fx:id="valor" style="-fx-border-color: black;" />
                        <Label disable="true" text="Código do produto">
                           <VBox.margin>
                              <Insets bottom="3.0" left="2.0" top="10.0" />
                           </VBox.margin>
                           <font>
                              <Font name="Droid Sans Bold" size="12.0" />
                           </font>
                        </Label>
                        <TextField fx:id="codigo" disable="true" style="-fx-border-color: black;" />
                     </children>
                     <HBox.margin>
                        <Insets left="30.0" top="25.0" />
                     </HBox.margin>
                  </VBox>
                  <HBox alignment="TOP_RIGHT" prefHeight="100.0" prefWidth="470.0">
                     <children>
                        <VBox prefHeight="200.0" prefWidth="250.0">
                           <HBox.margin>
                              <Insets bottom="25.0" right="30.0" top="44.0" />
                           </HBox.margin>
                           <children>
                              <Button mnemonicParsing="false" onAction="#salvarEContinuar" prefWidth="250.0" style="-fx-border-color: black;" text="Salvar e cadastrar novo produto">
                                 <font>
                                    <Font name="Droid Sans Bold" size="12.0" />
                                 </font>
                                 <padding>
                                    <Insets bottom="5.0" top="5.0" />
                                 </padding>
                              </Button>
                              <Button mnemonicParsing="false" onAction="#salvarESair" prefWidth="250.0" style="-fx-border-color: black;" text="Salvar e sair">
                                 <VBox.margin>
                                    <Insets top="10.0" />
                                 </VBox.margin>
                                 <font>
                                    <Font name="Droid Sans Bold" size="12.0" />
                                 </font>
                                 <padding>
                                    <Insets bottom="5.0" top="5.0" />
                                 </padding>
                              </Button>
                              <Button mnemonicParsing="false" onAction="#sair" prefWidth="250.0" style="-fx-border-color: black;" text="Sair">
                                 <VBox.margin>
                                    <Insets top="10.0" />
                                 </VBox.margin>
                                 <font>
                                    <Font name="Droid Sans Bold" size="12.0" />
                                 </font>
                                 <padding>
                                    <Insets bottom="5.0" top="5.0" />
                                 </padding>
                              </Button>
                           <VBox fx:id="erroContainer" alignment="TOP_LEFT" prefWidth="250.0" visible="false" fillWidth="true">
                              <children>
                                 <Label text="Erro" textFill="#e10c0c">
                                    <font>
                                       <Font name="Droid Sans Bold" size="16.0" />
                                    </font>
                                    <VBox.margin>
                                       <Insets bottom="3.0" left="2.0" />
                                    </VBox.margin>
                                 </Label>
                                 <HBox alignment="TOP_LEFT" prefWidth="250.0" style="-fx-background-color: #eaeaea;">
                                    <children>
                                       <Label fx:id="erroMessage"
                                              wrapText="true"
                                              maxWidth="Infinity"
                                              textAlignment="LEFT"
                                              alignment="TOP_LEFT"
                                              textFill="#e10c0c"
                                              HBox.hgrow="ALWAYS" />
                                    </children>
                                 </HBox>
                              </children>
                              </VBox>
                           </children>
                        </VBox>
                     </children>
                  </HBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
